{
  "name": "cracker_studio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "desktop/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:linux": "electron . --no-sandbox --ozone-platform=x11",
    "electron": "electron . --no-sandbox",
    "start:linux": "concurrently \"npm run dev\" \"npm run electron:linux\"",
    "start": "concurrently \"npm run dev\" \"npm run electron\""
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "custom-electron-titlebar": "^4.4.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}
